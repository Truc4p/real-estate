generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  role          UserRole  @default(BUYER)
  
  properties    Property[]
  favorites     Favorite[]
  savedSearches SavedSearch[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("users")
}

model Property {
  id           String         @id @default(cuid())
  title        String
  description  String
  price        Float
  address      String
  city         String
  state        String
  zipCode      String
  latitude     Float
  longitude    Float
  bedrooms     Int
  bathrooms    Float
  squareFeet   Int
  propertyType PropertyType
  listingType  ListingType
  status       PropertyStatus @default(ACTIVE)
  images       String[]
  features     String[]
  yearBuilt    Int
  virtualTourUrl String?      // Optional Matterport or 3D tour URL
  floorPlans   String[]       @default([]) // Array of floor plan image URLs
  
  // Advanced filters
  parking         ParkingType?
  amenities       String[]       @default([]) // pool, gym, doorman, etc.
  moveInDate      DateTime?      // Available move-in date
  leaseTerm       Int?           // Lease term in months (for rentals)
  incomeRequirement Float?       // Monthly income requirement
  creditRequirement Int?         // Minimum credit score
  openHouseDate   DateTime?      // Next open house date
  priceReduced    Boolean        @default(false) // Recently reduced price
  originalPrice   Float?         // Original price if reduced
  
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  favorites    Favorite[]
  neighborhood NeighborhoodData?
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  @@index([city, state])
  @@index([propertyType])
  @@index([listingType])
  @@index([status])
  @@index([price])
  @@index([priceReduced])
  @@index([moveInDate])
  @@map("properties")
}

model NeighborhoodData {
  id            String   @id @default(cuid())
  propertyId    String   @unique
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  // Scores
  walkScore     Int?     // 0-100
  transitScore  Int?     // 0-100
  bikeScore     Int?     // 0-100
  
  // Schools
  schools       Json?    // Array of school objects with name, rating, distance, grades
  
  // Crime statistics
  crimeRate     String?  // e.g., "Low", "Medium", "High"
  crimeScore    Int?     // 0-100 (higher is safer)
  crimeData     Json?    // Detailed crime statistics
  
  // Nearby amenities
  amenities     Json?    // Array of nearby restaurants, shops, parks with distance
  
  // Demographics
  demographics  Json?    // Population, median age, median income, etc.
  
  // Area pricing
  avgRentPrice  Float?   // Average rent in area
  avgSalePrice  Float?   // Average sale price in area
  pricePerSqFt  Float?   // Average price per sq ft
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("neighborhood_data")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
  
  @@unique([userId, propertyId])
  @@map("favorites")
}

model SavedSearch {
  id                  String   @id @default(cuid())
  name                String
  filters             Json     // Search filters (price, bedrooms, location, etc.)
  
  // Alert preferences
  emailAlerts         Boolean  @default(true)
  alertFrequency      AlertFrequency @default(INSTANT) // How often to send alerts
  notifyNewMatches    Boolean  @default(true)
  notifyPriceDrops    Boolean  @default(true)
  notifyStatusChanges Boolean  @default(true)
  
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  alerts              Alert[]
  lastChecked         DateTime @default(now())
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@map("saved_searches")
}

model Alert {
  id             String      @id @default(cuid())
  type           AlertType
  propertyId     String
  savedSearchId  String?
  
  // Alert details
  title          String
  message        String
  metadata       Json?       // Additional data (old price, new price, etc.)
  
  // Delivery status
  sent           Boolean     @default(false)
  sentAt         DateTime?
  read           Boolean     @default(false)
  readAt         DateTime?
  
  savedSearch    SavedSearch? @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime    @default(now())
  
  @@index([savedSearchId])
  @@index([sent])
  @@index([createdAt])
  @@map("alerts")
}

model PriceHistory {
  id         String   @id @default(cuid())
  propertyId String
  oldPrice   Float
  newPrice   Float
  changedAt  DateTime @default(now())
  
  @@index([propertyId])
  @@index([changedAt])
  @@map("price_history")
}

model StatusHistory {
  id         String         @id @default(cuid())
  propertyId String
  oldStatus  PropertyStatus
  newStatus  PropertyStatus
  changedAt  DateTime       @default(now())
  
  @@index([propertyId])
  @@index([changedAt])
  @@map("status_history")
}

enum UserRole {
  BUYER
  SELLER
  AGENT
  ADMIN
}

enum PropertyType {
  HOUSE
  APARTMENT
  CONDO
  TOWNHOUSE
  LAND
  COMMERCIAL
}

enum ListingType {
  FOR_SALE
  FOR_RENT
}

enum PropertyStatus {
  ACTIVE
  PENDING
  SOLD
  RENTED
}

enum ParkingType {
  GARAGE
  STREET
  NONE
  COVERED
  CARPORT
}

enum AlertType {
  NEW_MATCH
  PRICE_DROP
  STATUS_CHANGE
  BACK_ON_MARKET
}

enum AlertFrequency {
  INSTANT
  DAILY
  WEEKLY
}
