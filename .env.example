# Environment Variables
DATABASE_URL="postgresql://user:password@localhost:5432/realestate?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# Mapbox (Free - no billing required for development)
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token-here"

# Google Maps (Optional - for Street View feature)
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable: Maps Embed API
# Note: Requires billing enabled but includes $200/month free credit
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# Email (Optional)
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="noreply@yourdomain.com"

# Alert System Email Configuration
# Choose one email provider below

# Option 1: Nodemailer (SMTP) - Good for development with Gmail
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM="Real Estate Alerts <noreply@yourdomain.com>"

# Option 2: Resend - Recommended for production
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM="Real Estate Alerts <noreply@yourdomain.com>"

# Cron Job Secret (for scheduled alert checks)
CRON_SECRET=your-random-secret-key-here
